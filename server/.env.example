# Database: SQLite for local dev, PostgreSQL for production
# SQLite:      DATABASE_URL="file:./dev.db"
# PostgreSQL:  DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_URL="file:./dev.db"

# Server port
PORT=3001

# Allowed CORS origins (comma-separated)
# For production, set to your Vercel frontend URL
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# JWT secret — MUST change for production!
JWT_SECRET=discord-app-secret-key-change-in-production

# Node environment
NODE_ENV=development

# Optional: public origin for absolute upload URLs (avatars, chat wallpapers).
# On Render, RENDER_EXTERNAL_URL is set automatically — upload responses use it so the Vercel app can load /uploads without relying only on VITE_API_URL.
# Override if needed (no trailing slash):
# PUBLIC_BASE_URL=https://your-api.onrender.com
