# Optional in dev (Vite proxies /api, /uploads, /socket.io to localhost:3001).
# Required for production — set to your deployed server URL (no trailing slash):
# VITE_API_URL=https://your-server.onrender.com
#
# Optional: if uploads/static files are served from another origin (CDN), set this so
# relative /uploads/... URLs resolve correctly when VITE_API_URL is wrong or missing:
# VITE_UPLOADS_BASE_URL=https://your-server.onrender.com
